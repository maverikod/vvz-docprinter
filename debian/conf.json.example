{
  "server": {
    "host": "0.0.0.0",
    "port": 9001,
    "protocol": "http",
    "servername": "0.0.0.0",
    "ssl": null,
    "rules": null,
    "log_dir": "./logs",
    "debug": false,
    "log_level": "INFO",
    "advertised_host": null
  },
  "client": {
    "enabled": false,
    "protocol": "http",
    "ssl": null
  },
  "registration": {
    "enabled": true,
    "protocol": "https",
    "register_url": "https://192.168.254.26:3004/register",
    "unregister_url": "https://192.168.254.26:3004/unregister",
    "heartbeat_interval": 30,
    "server_id": "docprinter",
    "server_name": "docprinter",
    "instance_uuid": null,
    "auto_on_startup": true,
    "auto_on_shutdown": true,
    "metadata": {
      "server_id": "docprinter",
      "server_name": "Document printer for 1C",
      "description": "Python based template printer engine.\n\n###Execute: `call_server(server_id=\"docprinter\", copy_number=1, command=\"<name>\", params={...})`",
      "version": "0.2.0-4"
    },
    "heartbeat": {
      "url": "https://192.168.254.26:3004/proxy/heartbeat",
      "interval": 30
    },
    "ssl": {
      "crl": null,
      "dnscheck": false,
      "check_hostname": false
    }
  },
  "server_validation": {
    "enabled": false,
    "protocol": "http",
    "ssl": null,
    "timeout": 10,
    "use_token": false,
    "use_roles": false,
    "tokens": {},
    "roles": {},
    "auth_header": "X-API-Key",
    "roles_header": "X-Roles",
    "health_path": "/health",
    "check_hostname": false
  },
  "auth": {
    "use_token": false,
    "use_roles": false,
    "tokens": {},
    "roles": {}
  },
  "queue_manager": {
    "enabled": true,
    "in_memory": true,
    "registry_path": null,
    "shutdown_timeout": 30.0,
    "max_concurrent_jobs": 10,
    "max_queue_size": null,
    "per_job_type_limits": null,
    "completed_job_retention_seconds": 21600,
    "default_poll_interval": 0.0,
    "default_max_wait_time": null,
    "command_timeout": null,
    "stop_job_wait_timeout": null
  },
  "orchestration": {
    "discovery_enabled": false,
    "polling_interval": 30.0,
    "initial_poll_timeout": 60.0,
    "stale_snapshot_behavior": "keep",
    "mutex_lock_timeout": 5.0,
    "static_servers": []
  },
  "docprinter": {
    "output_dir": "runtime/output",
    "work_dir": "runtime/work",
    "output_ttl_seconds": 3600,
    "sweep_interval_seconds": 300,
    "trace_log_file": "logs/docprinter-trace.log"
  }
}
